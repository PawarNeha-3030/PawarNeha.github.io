-- States table
CREATE TABLE states (
    id INTEGER PRIMARY KEY,
    name TEXT NOT NULL,
    code TEXT NOT NULL
);

-- Districts table
CREATE TABLE districts (
    id INTEGER PRIMARY KEY,
    name TEXT NOT NULL,
    state_id INTEGER,
    latitude REAL,
    longitude REAL,
    FOREIGN KEY (state_id) REFERENCES states(id)
);

-- Villages table (for major villages)
CREATE TABLE villages (
    id INTEGER PRIMARY KEY,
    name TEXT NOT NULL,
    district_id INTEGER,
    pincode TEXT,
    latitude REAL,
    longitude REAL,
    FOREIGN KEY (district_id) REFERENCES districts(id)
);

-- User locations table
CREATE TABLE user_locations (
    id INTEGER PRIMARY KEY AUTOINCREMENT,
    user_id TEXT,
    latitude REAL,
    longitude REAL,
    village TEXT,
    district TEXT,
    state TEXT,
    pincode TEXT,
    accuracy REAL,
    timestamp DATETIME DEFAULT CURRENT_TIMESTAMP,
    source TEXT DEFAULT 'gps'  -- 'gps' or 'manual'
);